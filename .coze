[project]
sub_id = "0769734a"
name = "global-trust-ledger"
requires = ["nodejs-24"]
project_type = "web"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "./scripts/coze-preview-build.sh"]
run = ["bash", "./scripts/coze-preview-run.sh"]

[deploy.profile]
kind = "service"
flavor = "web"

[deploy]
build = ["bash", "./scripts/build.sh"]
run = ["bash", "./scripts/start.sh"]

[deploy.backend]
enabled = true

[subprojects]
path = ["."]
