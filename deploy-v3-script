#!/bin/bash
# 正道驿站 全自动部署 v3（零停机）
set -eo pipefail
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
log()   { echo -e "${GREEN}[INFO]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }
header(){ echo -e "${CYAN}━━━ $1 ━━━${NC}"; }
APP_DIR="/root/zhengdao"
VERSION="deploy-$(date +%Y%m%d-%H%M%S)"
START_TIME=$(date +%s)
cd "$APP_DIR"
header "正道驿站 全自动部署 v3（零停机）"
echo "时间: $(date)"; echo "版本: $VERSION"; echo ""

header "[1/10] 预检查"
DISK_AVAIL=$(df / | tail -1 | awk '{print $4}')
echo "  磁盘: $((DISK_AVAIL/1024))MB 可用"
if [ "$DISK_AVAIL" -lt 524288 ]; then error "磁盘不足"; exit 1; fi
if [ ! -d "node_modules" ]; then warn "node_modules 不存在"; fi
echo "  node_modules OK"
OLD_RUNNING=false; OLD_INSTANCES=0
if pm2 list 2>/dev/null | grep -q "zhengdao.*online"; then
  OLD_RUNNING=true; OLD_INSTANCES=$(pm2 list 2>/dev/null | grep "zhengdao" | wc -l)
  log "旧版运行中 ($OLD_INSTANCES 实例)"
else
  warn "旧版未运行，直接启动新版"
fi

# 生成集群模式 PM2 配置（实现零停机滚动重启）
cat > /tmp/ecosystem.zhengdao.js << 'PM2EOF'
module.exports = {
  apps: [{
    name: 'zhengdao',
    script: './server.js',
    instances: 2,
    exec_mode: 'cluster',
    autorestart: true,
    watch: false,
    max_memory_restart: '1G',
    listen_timeout: 30000,
    kill_timeout: 10000,
    env: {
      NODE_ENV: 'production',
      PORT: 5000,
      HOST: '0.0.0.0'
    }
  }]
};
PM2EOF
log "PM2 集群配置已生成（2 实例，滚动重启）"

header "[2/10] 备份"
MY_BACKUP_DIR="/root/backups/zhengdao_$(date +%Y%m%d_%H%M%S)"
mkdir -p "$MY_BACKUP_DIR"
cp .env "$MY_BACKUP_DIR/" 2>/dev/null || true
cp ecosystem.config.js /tmp/ecosystem.zhengdao.js "$MY_BACKUP_DIR/" 2>/dev/null || true
cp next.config.js "$MY_BACKUP_DIR/" 2>/dev/null || true
log "备份目录: $MY_BACKUP_DIR"
if [ -d ".next" ]; then rm -rf /tmp/next-rollback 2>/dev/null; cp -r .next /tmp/next-rollback; fi

header "[3/10] 拉取代码"
if [ -d ".git" ]; then git stash 2>/dev/null || true; git pull 2>&1; else warn "非 Git 仓库"; fi

header "[4/10] 安装依赖"
npm install 2>&1 || { warn "npm install 失败，清理重试..."; npm cache clean --force 2>/dev/null; rm -rf node_modules package-lock.json; npm install 2>&1; } || { error "npm install 重试失败"; exit 1; }
warn "跳过 npm audit fix"

header "[5/10] 构建"
rm -rf .next
npm run build 2>&1 || { error "构建失败"; [ -d /tmp/next-rollback ] && warn "旧版继续运行"; exit 1; }
log "构建成功"

header "[6/10] 部署静态文件"
mkdir -p .next/standalone/public
cp -r public/* .next/standalone/public/ 2>/dev/null || true
mkdir -p .next/standalone/.next
cp -r .next/static .next/standalone/.next/static
cp /tmp/ecosystem.zhengdao.js .next/standalone/ecosystem.config.js

header "[7/10] 零停机切换（滚动重启）"
cd "$APP_DIR/.next/standalone"
if [ "$OLD_RUNNING" = true ]; then
  log "集群模式滚动重启（逐个切换，零停机）..."
  pm2 reload ecosystem.config.js --update-env 2>&1
  sleep 4
  # 验证
  for i in 1 2 3; do
    if curl -s -o /dev/null -w "%{http_code}" http://localhost:5000 --max-time 5 2>/dev/null | grep -q "200"; then
      log "滚动重启成功"; break
    fi
    [ "$i" -lt 3 ] && sleep 2
  done
  # 如果验证失败，尝试直接启动
  if ! curl -s -o /dev/null -w "%{http_code}" http://localhost:5000 --max-time 5 2>/dev/null | grep -q "200"; then
    warn "滚动重启验证未通过，尝试直启..."
    pm2 start ecosystem.config.js --update-env 2>&1 || true
    sleep 3
  fi
else
  pm2 start ecosystem.config.js --update-env 2>&1; sleep 3
fi
cd "$APP_DIR"

header "[8/10] 验证"; sleep 2
SITE_CODE=$(curl -s -o /dev/null -w "%{http_code}" https://myfriends.vip --max-time 10 2>/dev/null || echo "000")
CSS_FILE=$(ls .next/static/css/ 2>/dev/null | head -1); CSS_CODE="000"
[ -n "$CSS_FILE" ] && CSS_CODE=$(curl -s -o /dev/null -w "%{http_code}" "https://myfriends.vip/_next/static/css/$CSS_FILE" --max-time 10 2>/dev/null || echo "000")
PM2_COUNT=$(pm2 list 2>/dev/null | grep "zhengdao.*online" | wc -l)
echo "  站点: $SITE_CODE  CSS: $CSS_CODE  实例: $PM2_COUNT"
if [ "$SITE_CODE" = "200" ] && [ "$PM2_COUNT" -ge 1 ]; then
  log "验证通过"
else
  error "验证失败，正在回滚..."
  [ -d "/tmp/next-rollback" ] && { rm -rf "$APP_DIR/.next"; cp -r /tmp/next-rollback "$APP_DIR/.next"; }
  pm2 restart zhengdao 2>/dev/null || pm2 start ecosystem.config.js 2>/dev/null || true
  log "已回滚"; exit 1
fi

header "[9/10] 保存状态"; pm2 save --force 2>&1 | tail -1
header "[10/10] 部署报告"
END_TIME=$(date +%s); DURATION=$((END_TIME - START_TIME))
echo "  版本: $VERSION"; echo "  状态: 成功"
echo "  用时: $((DURATION/60))m$((DURATION%60))s"
echo "  站点: https://myfriends.vip ($SITE_CODE)"
echo "  PM2:  $PM2_COUNT 实例在线(集群模式)"
log "部署完成！pm2 logs zhengdao"