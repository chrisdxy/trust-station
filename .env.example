# 数据库配置
DB_HOST=数据库主机地址
DB_PORT=数据库端口
DB_USER=数据库用户名
DB_PASSWORD=数据库密码
DB_NAME=数据库名称

# JWT密钥
JWT_SECRET=请更换为生产环境的强密钥

# 短信服务配置
SMS_ACCESS_KEY=阿里云短信AccessKey
SMS_SECRET_KEY=阿里云短信SecretKey
SMS_SIGNATURE=短信签名
SMS_TEMPLATE_CODE=短信模板CODE

# 微信登录配置
WECHAT_APPID=微信开放平台AppID
WECHAT_APPSECRET=微信开放平台AppSecret
NEXT_PUBLIC_WECHAT_APPID=微信开放平台AppID（前端使用）

# AI服务配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 文件上传配置（如需要）
# AWS_S3_BUCKET=存储桶名称
# AWS_ACCESS_KEY_ID=AWS访问密钥ID
# AWS_SECRET_ACCESS_KEY=AWS秘密访问密钥
# AWS_REGION=AWS区域
